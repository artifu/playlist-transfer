{
  "name": "playlist-transfer",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "build": "tsc -p tsconfig.build.json",
    "check": "tsc --noEmit -p tsconfig.json",
    "test": "node --test tests/*.test.js",
    "dev:api": "npm run build && node tools/playlist-preview-server.mjs",
    "dev:transfer-api": "node --disable-warning=ExperimentalWarning apps/transfer-api/server.mjs",
    "dev:web": "node apps/web/server.mjs",
    "brand:sync": "node tools/sync-brand-assets.mjs",
    "brand:check": "node tools/sync-brand-assets.mjs --check",
    "analytics:report": "wrangler d1 execute playlist-transfer --remote --file=tools/analytics-report.sql",
    "spotify:auth": "node tools/spotify-auth-helper.mjs",
    "spotify:public-probe": "npm run build && node dist/cli/spotify-public-probe.js",
    "apple:developer-token": "npm run build && node dist/cli/generate-apple-developer-token.js",
    "apple:user-token": "node tools/serve-apple-user-token-helper.mjs",
    "transfer:dry": "npm run build && node dist/cli/transfer.js --dry-run",
    "transfer": "npm run build && node dist/cli/transfer.js"
  },
  "dependencies": {
    "dotenv": "^16.4.5",
    "jose": "^6.2.2"
  },
  "devDependencies": {
    "@types/node": "^22.15.3",
    "tsx": "^4.19.3",
    "typescript": "^5.8.3",
    "wrangler": "^4.95.0"
  }
}
