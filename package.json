{
  "name": "playlist-transfer",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "check": "tsc --noEmit -p tsconfig.json",
    "dev:api": "node --import tsx src/cli/server.ts",
    "spotify:auth": "node tools/spotify-auth-helper.mjs",
    "apple:developer-token": "node --import tsx src/cli/generate-apple-developer-token.ts",
    "apple:user-token": "node tools/serve-apple-user-token-helper.mjs",
    "transfer:dry": "node --import tsx src/cli/transfer.ts --dry-run",
    "transfer": "node --import tsx src/cli/transfer.ts"
  },
  "dependencies": {
    "dotenv": "^16.4.5",
    "fastify": "^5.8.5",
    "jose": "^6.2.2"
  },
  "devDependencies": {
    "@types/node": "^22.15.3",
    "tsx": "^4.19.3",
    "typescript": "^5.8.3"
  }
}
